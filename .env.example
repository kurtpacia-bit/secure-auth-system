# ========================================
# Secure Auth System - Environment Variables
# ========================================

# FLASK CONFIGURATION
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secure-random-key-here-min-32-chars

# SUPABASE CONFIGURATION
# Get from: https://supabase.com/dashboard/project/[project-id]/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# SECURITY CONFIGURATION
PEPPER=your-64-char-hex-pepper-for-password-hashing
CSRF_TOKEN_LENGTH=32

# RATE LIMITING
RATE_LIMIT_LOGIN=5 per 15 minutes
RATE_LIMIT_REGISTER=3 per 1 hour
RATE_LIMIT_API=100 per 1 hour

# EMAIL CONFIGURATION
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAIL_FROM=noreply@secureauth.com
EMAIL_FROM_NAME=SecureAuth

# TOKEN CONFIGURATION
VERIFICATION_TOKEN_EXPIRY=24  # hours
PASSWORD_RESET_TOKEN_EXPIRY=1  # hours
SESSION_TIMEOUT=30  # minutes

# ACCOUNT LOCKOUT CONFIGURATION
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=1800  # seconds (30 minutes)

# HTTPS CONFIGURATION
ENFORCE_HTTPS=True
HSTS_MAX_AGE=31536000  # 1 year in seconds
HSTS_INCLUDE_SUBDOMAINS=True

# LOGGING CONFIGURATION
LOG_LEVEL=INFO
LOG_FILE=logs/auth.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=10

# OPTIONAL: Sentry (Error Tracking)
SENTRY_DSN=

# OPTIONAL: Database Backups
DATABASE_BACKUP_ENABLED=False
BACKUP_SCHEDULE=daily
